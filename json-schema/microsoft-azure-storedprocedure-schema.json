{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/StoredProcedure",
  "title": "StoredProcedure",
  "type": "object",
  "description": "A Cosmos DB stored procedure.",
  "properties": {
    "id": {
      "type": "string",
      "description": "The unique name of the stored procedure.",
      "example": "abc123"
    },
    "body": {
      "type": "string",
      "description": "The body of the stored procedure (JavaScript function).",
      "example": "example_value"
    },
    "_rid": {
      "type": "string",
      "readOnly": true,
      "example": "500123"
    },
    "_ts": {
      "type": "integer",
      "readOnly": true,
      "example": 10
    },
    "_self": {
      "type": "string",
      "readOnly": true,
      "example": "example_value"
    },
    "_etag": {
      "type": "string",
      "readOnly": true,
      "example": "example_value"
    }
  },
  "required": [
    "id",
    "body"
  ]
}