{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StorageServiceProperties",
  "type": "object",
  "description": "Storage service properties.",
  "properties": {
    "Logging": {
      "type": "object",
      "description": "Azure Analytics logging settings."
    },
    "Cors": {
      "type": "object",
      "description": "The set of CORS rules."
