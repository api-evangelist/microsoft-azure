{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/StoredProcedureListResult",
  "title": "StoredProcedureListResult",
  "type": "object",
  "description": "List of Cosmos DB stored procedures.",
  "properties": {
    "_rid": {
      "type": "string",
      "readOnly": true,
      "example": "500123"
    },
    "StoredProcedures": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/StoredProcedure"
      },
      "description": "List of stored procedures.",
      "example": []
    },
    "_count": {
      "type": "integer",
      "readOnly": true,
      "example": 10
    }
  }
}