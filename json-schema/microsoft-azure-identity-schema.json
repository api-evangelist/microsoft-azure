{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Identity",
  "title": "Identity",
  "type": "object",
  "description": "Identity for the resource.",
  "properties": {
    "principalId": {
      "type": "string",
      "readOnly": true,
      "example": "500123"
    },
    "tenantId": {
      "type": "string",
      "readOnly": true,
      "example": "500123"
    },
    "type": {
      "type": "string",
      "enum": [
        "None",
        "SystemAssigned",
        "UserAssigned",
        "SystemAssigned, UserAssigned"
      ],
      "example": "None"
    },
    "userAssignedIdentities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "principalId": {
            "type": "string",
            "readOnly": true
          },
          "clientId": {
            "type": "string",
            "readOnly": true
          }
        }
      },
      "example": "example_value"
    }
  }
}