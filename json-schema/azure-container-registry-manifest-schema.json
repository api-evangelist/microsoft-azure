{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Manifest",
  "type": "object",
  "description": "Docker V2 manifest.",
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "description": "Schema version."
    },
    "mediaType": {
      "type": "string",
      "description": "Media type."
    },
    "layers": {
      "type": "array",
      "description": "List of layer descriptors."
    }
  }
}