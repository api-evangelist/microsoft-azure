{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ItemListResult",
  "title": "ItemListResult",
  "type": "object",
  "description": "List of Cosmos DB items.",
  "properties": {
    "_rid": {
      "type": "string",
      "readOnly": true,
      "example": "500123"
    },
    "Documents": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Item"
      },
      "description": "List of items.",
      "example": []
    },
    "_count": {
      "type": "integer",
      "readOnly": true,
      "example": 10
    }
  }
}