{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SubscriptionPolicies",
  "title": "SubscriptionPolicies",
  "type": "object",
  "description": "Subscription policies.",
  "properties": {
    "locationPlacementId": {
      "type": "string",
      "readOnly": true,
      "description": "The subscription location placement ID.",
      "example": "500123"
    },
    "quotaId": {
      "type": "string",
      "readOnly": true,
      "description": "The subscription quota ID.",
      "example": "500123"
    },
    "spendingLimit": {
      "type": "string",
      "readOnly": true,
      "description": "The subscription spending limit.",
      "enum": [
        "On",
        "Off",
        "CurrentPeriodOff"
      ],
      "example": "On"
    }
  }
}