{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CertificateAttributes",
  "title": "CertificateAttributes",
  "type": "object",
  "description": "The certificate management attributes.",
  "properties": {
    "enabled": {
      "type": "boolean",
      "example": true
    },
    "nbf": {
      "type": "integer",
      "example": 10
    },
    "exp": {
      "type": "integer",
      "example": 10
    },
    "created": {
      "type": "integer",
      "readOnly": true,
      "example": 10
    },
    "updated": {
      "type": "integer",
      "readOnly": true,
      "example": 10
    },
    "recoveryLevel": {
      "type": "string",
      "readOnly": true,
      "example": "example_value"
    },
    "recoverableDays": {
      "type": "integer",
      "readOnly": true,
      "example": 10
    }
  }
}