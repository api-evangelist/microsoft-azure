{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TagAttributesBase",
  "type": "object",
  "description": "Tag attribute details.",
  "properties": {
    "name": {
      "type": "string",
      "description": "Tag name."
    },
    "digest": {
      "type": "string",
      "description": "Tag digest."
    },
    "createdTime": {
      "type": "string"
    },
    "lastUpdateTime": {
      "type": "string"
    },
    "signed": {
      "type": "boolean",
      "description": "Whether the tag is signed."
    }
  }
}