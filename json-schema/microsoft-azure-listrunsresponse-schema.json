{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/listRunsResponse",
  "title": "listRunsResponse",
  "type": "object",
  "properties": {
    "object": {
      "type": "string",
      "example": "list"
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/runObject"
      }
    },
    "first_id": {
      "type": "string",
      "example": "run_hLBK7PXBv5Lr2NQT7KLY0ag1"
    },
    "last_id": {
      "type": "string",
      "example": "run_QLoItBbqwyAJEzlTy4y9kOMM"
    },
    "has_more": {
      "type": "boolean",
      "example": false
    }
  },
  "required": [
    "object",
    "data",
    "first_id",
    "last_id",
    "has_more"
  ]
}