{
  "opencollection": "1.0.0",
  "info": {
    "name": "Microsoft Azure Azure Container Registry API",
    "version": "2023-07-01"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "implicit",
      "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/authorize",
      "credentials": {
        "clientId": "{{clientId}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Catalog",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Microsoft Azure List Repositories",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{registryName}.azurecr.io/acr/v1/_catalog",
            "params": [
              {
                "name": "last",
                "value": "example_value",
                "type": "query",
                "description": "Query parameter for the last item in the previous call."
              },
              {
                "name": "n",
                "value": "10",
                "type": "query",
                "description": "Number of repositories to return."
              }
            ]
          },
          "docs": "List repositories in the registry."
        }
      ]
    },
    {
      "info": {
        "name": "Repositories",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Microsoft Azure Get Repository Attributes",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{registryName}.azurecr.io/acr/v1/:name",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              }
            ]
          },
          "docs": "Get repository attributes."
        },
        {
          "info": {
            "name": "Microsoft Azure Update Repository Attributes",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://{registryName}.azurecr.io/acr/v1/:name",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update the attribute identified by name where reference is the tag or digest."
        },
        {
          "info": {
            "name": "Microsoft Azure Delete a Repository",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://{registryName}.azurecr.io/acr/v1/:name",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              }
            ]
          },
          "docs": "Delete the repository identified by name."
        }
      ]
    },
    {
      "info": {
        "name": "Default",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Microsoft Azure List Tags",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{registryName}.azurecr.io/acr/v1/:name/_tags",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              },
              {
                "name": "last",
                "value": "example_value",
                "type": "query",
                "description": "Query parameter for the last item in previous call."
              },
              {
                "name": "n",
                "value": "10",
                "type": "query",
                "description": "Number of tags to return."
              },
              {
                "name": "orderby",
                "value": "timedesc",
                "type": "query",
                "description": "Orderby query parameter."
              },
              {
                "name": "digest",
                "value": "example_value",
                "type": "query",
                "description": "Filter by digest."
              }
            ]
          },
          "docs": "List tags of a repository."
        },
        {
          "info": {
            "name": "Microsoft Azure Get Tag Attributes",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{registryName}.azurecr.io/acr/v1/:name/_tags/:reference",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              },
              {
                "name": "reference",
                "value": "example_value",
                "type": "path",
                "description": "Tag name."
              }
            ]
          },
          "docs": "Get tag attributes by tag."
        },
        {
          "info": {
            "name": "Microsoft Azure Delete a Tag",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://{registryName}.azurecr.io/acr/v1/:name/_tags/:reference",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              },
              {
                "name": "reference",
                "value": "example_value",
                "type": "path",
                "description": "Tag name."
              }
            ]
          },
          "docs": "Delete tag by name."
        }
      ]
    },
    {
      "info": {
        "name": "Manifests",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Microsoft Azure List Manifests",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{registryName}.azurecr.io/acr/v1/:name/_manifests",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              },
              {
                "name": "last",
                "value": "example_value",
                "type": "query",
                "description": "Query parameter for the last item in previous call."
              },
              {
                "name": "n",
                "value": "10",
                "type": "query",
                "description": "Number of manifests to return."
              },
              {
                "name": "orderby",
                "value": "timedesc",
                "type": "query",
                "description": "Orderby query parameter."
              }
            ]
          },
          "docs": "List manifests of a repository."
        },
        {
          "info": {
            "name": "Microsoft Azure Get a Manifest",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{registryName}.azurecr.io/v2/:name/manifests/:reference",
            "headers": [
              {
                "name": "Accept",
                "value": "example_value"
              }
            ],
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              },
              {
                "name": "reference",
                "value": "example_value",
                "type": "path",
                "description": "A tag or a digest, pointing to a specific image."
              }
            ]
          },
          "docs": "Get the manifest identified by name and reference."
        },
        {
          "info": {
            "name": "Microsoft Azure Put a Manifest",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://{registryName}.azurecr.io/v2/:name/manifests/:reference",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              },
              {
                "name": "reference",
                "value": "example_value",
                "type": "path",
                "description": "A tag or a digest, pointing to a specific image."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Put the manifest identified by name and reference."
        },
        {
          "info": {
            "name": "Microsoft Azure Delete a Manifest",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://{registryName}.azurecr.io/v2/:name/manifests/:reference",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "Name of the image (including the namespace)."
              },
              {
                "name": "reference",
                "value": "example_value",
                "type": "path",
                "description": "Digest of a manifest."
              }
            ]
          },
          "docs": "Delete the manifest identified by name and reference."
        }
      ]
    }
  ],
  "bundled": true
}