{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "BlobProperties",
  "type": "object",
  "properties": {
    "Creation-Time": {
      "type": "string"
    },
    "Last-Modified": {
      "type": "string"
    },
    "Etag": {
      "type": "string"
    },
    "Content-Length": {
      "type": "integer"
    },
    "Content-Type": {
      "type": "string"
    },
    "Content-Encoding": {
      "type": "string"
    },
    "Content-Language": {
      "type": "string"
    },
    "Content-MD5": {
      "type": "string"
    },
    "Content-Disposition": {
      "type": "string"
    },
    "Cache-Control": {
      "type": "string"
    },
    "BlobType": {
      "type": "string"
    },
    "AccessTier": {
      "type": "string"
    },
    "AccessTierInferred": {
      "type": "boolean"
    },
    "LeaseStatus": {
      "type": "string"
    },
    "LeaseState": {
      "type": "string"
    },
    "ServerEncrypted": {
      "type": "boolean"
    }
  }
}